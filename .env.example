# Azure SQL connection — copy to .env.local and fill in.
# In Vercel, set these as Environment Variables on the project.
AZURE_SQL_SERVER=your-server.database.windows.net
AZURE_SQL_DATABASE=your-database
AZURE_SQL_USER=your-user
AZURE_SQL_PASSWORD=your-password

# Zoho CRM — used to create a lead on every order submission.
# Generate via Zoho API Console: https://api-console.zoho.com
ZOHO_CLIENT_ID=your-client-id
ZOHO_CLIENT_SECRET=your-client-secret
ZOHO_REFRESH_TOKEN=your-refresh-token
